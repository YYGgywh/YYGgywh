/*
 * @file            frontend/src/components/DivinationInfo/DivinationInfo.css
 * @description     占卜信息组件样式文件，包含表单输入、模态框、时间选择器等UI元素的视觉样式
 * @author          Gordon <gordon_cao@qq.com>
 * @createTime      2026-02-23 00:00:00
 * @lastModified    2026-02-25 09:59:34
