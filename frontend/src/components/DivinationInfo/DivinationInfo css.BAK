*/

/* ========================================
   占卜信息组件样式
   设计思路：使用全局主题变量（variables.css），确保与整个应用的设计风格一致
   特点：表单输入、模态框、时间选择器、自定义组件样式
   ======================================== */

/* 主容器 - 整个占卜信息组件的外层容器 */
.divination-info-container {
  max-width: 800px;              /* 最大宽度限制，确保在大屏幕上不会过宽 */
  margin: 0 auto;                /* 水平居中 */
  padding: 10px;                 /* 内边距，为内容留出呼吸空间 */
  border: 1px solid var(--primary-color);  /* 主色边框，突出组件边界 */
  border-radius: var(--radius-xl);          /* 大圆角，营造柔和的视觉效果 */
}

/* 表单容器 - 包含所有表单元素的区域 */
.divination-form {
  border-radius: var(--radius-xl);          /* 与外层容器一致的圆角 */
  padding: 10px;                 /* 内边距，为表单元素提供空间 */
  background-color: var(--bg-white);       /* 白色背景，突出表单内容 */
  box-shadow: var(--shadow-md);            /* 中等阴影，营造层次感 */
}

/* 表单行 - 水平排列的表单元素组 */
.form-row {
  display: flex;                 /* 使用 Flexbox 布局 */
  gap: var(--spacing-lg);        /* 元素间距，保持视觉一致性 */
  margin-bottom: var(--spacing-xl);        /* 底部间距，区分不同表单组 */
  align-items: center;           /* 垂直居中对齐 */
}

/* 时间戳表单行 - 特殊的表单行，底部间距较小 */
.form-row-timestamp {
  margin-bottom: 5px;             /* 较小的底部间距，紧凑布局 */
}

/* ========================================
   基础输入框样式
   设计思路：统一输入框样式，提供一致的交互体验
   特点：固定高度、居中文本、焦点高亮效果
   ======================================== */

/* 基础输入框 - 所有输入框的通用样式 */
.input-base {
  height: 32px;                   /* 固定高度，确保视觉一致性 */
  padding: 0 var(--spacing-md);  /* 左右内边距，不使用上下内边距以保持高度 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  text-align: center;            /* 文本居中对齐 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐内容 */
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);  /* 快速过渡效果 */
}

/* 输入框焦点状态 - 提供视觉反馈 */
.input-base:focus {
  outline: none;                 /* 移除默认轮廓 */
  border-color: var(--primary-color);      /* 主色边框，突出焦点 */
  box-shadow: 0 0 0 2px var(--primary-focus);  /* 外发光效果，增强焦点提示 */
}

/* 输入框占位符样式 */
.input-base::placeholder {
  text-align: center;            /* 占位符文本居中 */
  color: var(--text-placeholder);        /* 占位符颜色，降低视觉干扰 */
}

/* 姓名输入框 - 姓和名分别使用固定宽度 */
.first-name-input,
.last-name-input {
  width: 80px;                   /* 固定宽度，适合输入 1-2 个字符 */
  padding: 0 var(--spacing-sm);  /* 较小的左右内边距，最大化输入空间 */
}

/* 出生年份输入框 - 较窄的宽度 */
.birth-year-input {
  width: 50px;                   /* 固定宽度，适合输入 4 位数字 */
  padding: 0 var(--spacing-sm);  /* 较小的左右内边距 */
}

/* 地点输入框 - 弹性宽度，占据剩余空间 */
.location-input {
  flex: 1;                       /* 弹性布局，自动占据剩余空间 */
  padding: 0 var(--spacing-lg);  /* 较大的左右内边距，提供舒适的输入体验 */
}

/* 子类型输入框 - 固定宽度 */
.sub-type-input {
  width: 80px;                   /* 固定宽度，适合输入简短的子类型 */
  padding: 0 var(--spacing-lg);  /* 较大的左右内边距 */
}

/* ========================================
   性别选择组件 - 单选按钮组
   设计思路：使用自定义单选按钮样式，隐藏原生 radio，提供更好的视觉效果
   特点：圆形指示器、选中状态高亮、悬停效果
   ======================================== */

/* 性别选择容器 - 包含性别单选按钮的区域 */
.gender-dropdown-container {
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  position: relative;            /* 相对定位，为绝对定位子元素提供参考 */
}

/* 性别单选按钮容器 */
.gender-radio-container {
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  position: relative;            /* 相对定位 */
}

/* 单选按钮组 - 水平排列的单选按钮 */
.radio-group {
  display: flex;                 /* 使用 Flexbox 布局 */
  gap: var(--spacing-sm);        /* 按钮间距 */
  align-items: center;           /* 垂直居中对齐 */
}

/* 单选按钮标签 - 包含自定义按钮和文本 */
.radio-label {
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  gap: var(--spacing-xs);        /* 按钮和文本之间的间距 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  position: relative;            /* 相对定位，为绝对定位子元素提供参考 */
}

/* 原生单选按钮 - 隐藏原生样式 */
.radio-input {
  position: absolute;            /* 绝对定位 */
  opacity: 0;                    /* 完全透明，隐藏元素 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
}

/* 自定义单选按钮 - 替代原生 radio 的视觉元素 */
.radio-custom {
  width: 16px;                   /* 固定宽度 */
  height: 16px;                  /* 固定高度 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: 50%;            /* 圆形边框 */
  background-color: var(--bg-white);       /* 白色背景 */
  position: relative;            /* 相对定位，为伪元素提供参考 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
}

/* 单选按钮选中状态 */
.radio-input:checked + .radio-custom {
  background-color: var(--primary-color);   /* 主色背景 */
  border-color: var(--primary-color);      /* 主色边框 */
}

/* 单选按钮选中状态的内圆 - 使用伪元素实现 */
.radio-input:checked + .radio-custom::after {
  content: '';                   /* 伪元素内容 */
  position: absolute;            /* 绝对定位 */
  top: 4px;                      /* 顶部偏移 */
  left: 4px;                     /* 左侧偏移 */
  width: 7px;                    /* 内圆宽度 */
  height: 7px;                   /* 内圆高度 */
  border-radius: 50%;            /* 圆形 */
  background-color: var(--bg-white);       /* 白色背景，形成对比 */
}

/* 单选按钮文本 */
.radio-text {
  font-size: var(--font-size-base);        /* 基础字体大小 */
  color: var(--text-primary);             /* 主要文本颜色 */
}

/* 单选按钮标签悬停效果 */
.radio-label:hover .radio-custom {
  border-color: var(--primary-color);      /* 主色边框，提示可交互 */
}

/* ========================================
   占卜类型下拉选择组件
   设计思路：自定义下拉选择器，提供更好的视觉体验和交互反馈
   特点：紧凑布局、悬停高亮、箭头指示器
   ======================================== */

/* 占卜类型容器 - 包含类型标签和下拉选择器 */
.divination-type-container {
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  position: relative;            /* 相对定位 */
}

/* 类型标签 - 占卜类型的文本标签 */
.type-label {
  font-size: var(--font-size-base);        /* 基础字体大小 */
  font-weight: 600;               /* 加粗字体，突出标签 */
  white-space: nowrap;           /* 防止文本换行 */
}

/* 下拉选择器容器 - 相对定位，为下拉菜单提供参考 */
.dropdown-container {
  position: relative;            /* 相对定位 */
}

/* 下拉选择器 - 显示当前选择的值 */
.dropdown-select {
  width: 50px;                   /* 固定宽度，紧凑布局 */
  height: 32px;                  /* 固定高度，与输入框一致 */
  padding: 0 var(--spacing-sm);  /* 左右内边距 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  display: flex;                 /* 使用 Flexbox 布局 */
  justify-content: space-between; /* 两端对齐，文本和箭头分开 */
  align-items: center;           /* 垂直居中对齐 */
  background-color: var(--bg-white);       /* 白色背景 */
  white-space: nowrap;           /* 防止文本换行 */
  overflow: hidden;              /* 隐藏溢出内容 */
  text-overflow: ellipsis;       /* 文本溢出时显示省略号 */
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);  /* 快速过渡效果 */
}

/* 下拉选择器焦点状态 */
.dropdown-select:focus {
  outline: none;                 /* 移除默认轮廓 */
  border-color: var(--primary-color);      /* 主色边框，突出焦点 */
  box-shadow: 0 0 0 2px var(--primary-focus);  /* 外发光效果，增强焦点提示 */
}

/* 下拉箭头 - 指示下拉菜单 */
.dropdown-arrow {
  font-size: var(--font-size-xs);         /* 极小字体 */
  color: var(--text-secondary);           /* 次要文本颜色 */
}

/* 下拉菜单 - 选项列表 */
.dropdown-menu {
  position: absolute;            /* 绝对定位 */
  top: 100%;                    /* 在选择器正下方 */
  left: 0;                      /* 左对齐 */
  background-color: var(--bg-white);       /* 白色背景 */
  border: 1px solid var(--border-color);   /* 边框颜色 */
  border-radius: var(--radius-lg);         /* 大圆角 */
  box-shadow: var(--shadow-sm);            /* 小阴影，营造层次感 */
  z-index: var(--z-dropdown);               /* 下拉菜单层级 */
  margin-top: var(--spacing-xs);           /* 顶部间距，与选择器分开 */
  min-width: 40px;               /* 最小宽度 */
}

/* 下拉菜单项 - 单个选项 */
.dropdown-item {
  padding: var(--spacing-xs) var(--spacing-sm);  /* 内边距 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: background-color var(--transition-fast);  /* 快速过渡效果 */
  white-space: nowrap;           /* 防止文本换行 */
  overflow: hidden;              /* 隐藏溢出内容 */
  text-overflow: ellipsis;       /* 文本溢出时显示省略号 */
}

/* 下拉菜单项悬停状态 */
.dropdown-item:hover {
  background-color: var(--bg-gray-light);  /* 浅灰背景，突出悬停项 */
  color: var(--primary-color);             /* 主色文本，增强视觉反馈 */
}

/* ========================================
   问题输入和时间戳显示
   设计思路：问题输入框使用文本域样式，时间戳显示为可点击的触发器
   特点：居中对齐、悬停效果、焦点高亮
   ======================================== */

/* 问题文本域 - 用于输入占卜问题的多行文本框 */
.question-textarea {
  flex: 1;                       /* 弹性布局，占据剩余空间 */
  height: 32px;                  /* 固定高度，与输入框一致 */
  padding: 0 var(--spacing-lg);  /* 左右内边距 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  min-height: 32px;              /* 最小高度 */
  line-height: 32px;             /* 行高与高度一致，确保垂直居中 */
  text-align: center;            /* 文本居中对齐 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐内容 */
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);  /* 快速过渡效果 */
}

/* 问题文本域焦点状态 */
.question-textarea:focus {
  outline: none;                 /* 移除默认轮廓 */
  border-color: var(--primary-color);      /* 主色边框，突出焦点 */
  box-shadow: 0 0 0 2px var(--primary-focus);  /* 外发光效果，增强焦点提示 */
}

/* 时间戳显示 - 显示当前选择的时间，点击可打开时间选择模态框 */
.timestamp {
  flex: 1;                       /* 弹性布局，占据剩余空间 */
  height: 32px;                  /* 固定高度，与输入框一致 */
  padding: 0 var(--spacing-lg);  /* 左右内边距 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  background-color: var(--bg-gray-light);  /* 浅灰背景，区别于输入框 */
  text-align: center;            /* 文本居中对齐 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐内容 */
  justify-content: center;       /* 水平居中对齐内容 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
  will-change: background-color, color;     /* 性能优化，提示浏览器这些属性会变化 */
}

/* 时间戳悬停状态 - 提示可交互 */
.timestamp:hover {
  background-color: var(--bg-gray-medium);  /* 中灰背景，增强悬停反馈 */
  color: var(--primary-color);             /* 主色文本，突出可交互性 */
}

/* ========================================
   模态框组件 - 通用模态框样式
   设计思路：使用固定定位覆盖全屏，居中显示模态框内容
   特点：半透明遮罩、阴影效果、层级管理
   ======================================== */

/* 模态框遮罩层 - 覆盖全屏的半透明背景 */
.modal-overlay {
  position: fixed;               /* 固定定位，相对于视口 */
  top: 0;                        /* 顶部对齐 */
  left: 0;                       /* 左侧对齐 */
  right: 0;                      /* 右侧对齐 */
  bottom: 0;                     /* 底部对齐 */
  background-color: rgba(0, 0, 0, 0.5);  /* 半透明黑色背景，淡化背景内容 */
  display: flex;                 /* 使用 Flexbox 布局 */
  justify-content: center;       /* 水平居中 */
  align-items: center;           /* 垂直居中 */
  z-index: var(--z-modal);        /* 模态框层级，确保在最上层 */
}

/* 模态框内容区 - 实际的模态框内容 */
.modal-content {
  background-color: var(--bg-white);       /* 白色背景 */
  border-radius: var(--radius-lg);         /* 大圆角 */
  box-shadow: var(--shadow-lg);            /* 大阴影，营造层次感 */
  width: 90%;                    /* 宽度占视口的 90% */
  max-width: 500px;              /* 最大宽度限制 */
  overflow: hidden;              /* 隐藏溢出内容，确保圆角效果 */
}

/* 时间戳模态框 - 特殊的时间选择模态框，宽度更大 */
.timestamp-modal {
  max-width: 600px;              /* 更大的最大宽度，适应时间选择器的需求 */
}

/* ========================================
   模态框头部 - 标题和关闭按钮
   设计思路：使用浅色背景区分头部，提供清晰的视觉层次
   特点：底部边框、关闭按钮、标签页切换
   ======================================== */

/* 模态框头部 - 包含标题和关闭按钮 */
.modal-header {
  display: flex;                 /* 使用 Flexbox 布局 */
  justify-content: flex-start;   /* 左对齐 */
  align-items: center;           /* 垂直居中对齐 */
  padding: var(--spacing-xl) var(--spacing-2xl);  /* 内边距 */
  border-bottom: 1px solid var(--border-color);   /* 底部边框，区分头部和内容 */
  background-color: var(--bg-gray-light);  /* 浅灰背景，突出头部区域 */
  flex-wrap: nowrap;             /* 防止换行 */
}

/* 时间戳标签页 - 阳历/阴历切换标签 */
.timestamp-tabs {
  display: flex;                 /* 使用 Flexbox 布局 */
  border-bottom: 1px solid var(--border-color);   /* 底部边框 */
  flex: 1;                       /* 弹性布局，占据剩余空间 */
  justify-content: center;       /* 水平居中 */
}

/* 标签页按钮 - 单个标签按钮 */
.tab-button {
  width: 50px;                   /* 固定宽度 */
  height: 30px;                  /* 固定高度 */
  padding: 0 var(--spacing-lg);  /* 左右内边距 */
  border: none;                  /* 无边框 */
  background: none;               /* 无背景 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  font-weight: 500;              /* 中等字重 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  border-bottom: 2px solid transparent;     /* 底部边框，默认透明 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  justify-content: center;       /* 水平居中对齐 */
}

/* 标签页按钮悬停状态 */
.tab-button:hover {
  color: var(--primary-color);   /* 主色文本，提示可交互 */
}

/* 标签页按钮激活状态 - 当前选中的标签 */
.tab-button.active {
  color: var(--primary-color);   /* 主色文本，突出当前选中 */
  background-color: var(--primary-light);  /* 主色浅色背景 */
  border-bottom-color: var(--primary-color);  /* 主色底部边框，强调选中状态 */
}

/* ========================================
   时间输入区 - 天干地支和时间选择
   设计思路：使用紧凑的输入框布局，支持天干地支和标准时间输入
   特点：小尺寸输入框、禁用状态、焦点高亮
   ======================================== */

/* 时间输入容器 - 包含所有时间输入框的区域 */
.timestamp-inputs {
  display: flex;                 /* 使用 Flexbox 布局 */
  gap: var(--spacing-2xl);       /* 较大的元素间距 */
  margin-bottom: var(--spacing-2xl);        /* 底部间距 */
  flex-wrap: wrap;               /* 允许换行，适应小屏幕 */
  justify-content: center;       /* 水平居中 */
  align-items: center;           /* 垂直居中对齐 */
}

/* 天干输入容器 - 特殊的天干输入区域 */
.tiangan-inputs {
  margin-bottom: 5px;             /* 较小的底部间距，紧凑布局 */
}

/* 天干和地支输入框 - 更小的尺寸 */
.tiangan-inputs .time-input,
.dizhi-inputs .time-input {
  width: 24px;                   /* 较小的宽度，适应单个字符 */
  height: 24px;                  /* 较小的高度 */
  padding: 2px;                   /* 较小的内边距 */
  border: 1px solid #ccc;        /* 特殊边框颜色，区分于其他输入框 */
  box-sizing: content-box;       /* 内容盒模型，确保尺寸准确 */
}

/* 时间输入框 - 通用的时间输入框样式 */
.time-input {
  height: 30px;                  /* 固定高度 */
  padding: 0 var(--spacing-xs);  /* 左右内边距 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  text-align: center;            /* 文本居中对齐 */
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);  /* 快速过渡效果 */
}

/* 时间输入框焦点状态 */
.time-input:focus {
  outline: none;                 /* 移除默认轮廓 */
  border-color: var(--primary-color);      /* 主色边框，突出焦点 */
  box-shadow: 0 0 0 2px var(--primary-focus);  /* 外发光效果，增强焦点提示 */
}

/* 年份输入框 - 较宽的宽度 */
.time-input-year {
  width: 60px;                   /* 较宽的宽度，适合输入 4 位数字 */
}

/* 小尺寸时间输入框 - 用于月、日、时等 */
.time-input-small {
  width: 40px;                   /* 中等宽度，适合输入 2 位数字 */
}

/* 时间输入框禁用状态 */
.time-input:disabled {
  background-color: var(--bg-gray-medium);  /* 中灰背景，表示禁用 */
  color: var(--text-disabled);    /* 禁用文本颜色 */
  cursor: not-allowed;           /* 禁用鼠标指针 */
  border-color: var(--border-color);        /* 保持边框颜色 */
}

/* ========================================
   闰月切换按钮 - 特殊的开关按钮
   设计思路：使用紧凑的按钮样式，支持激活和禁用状态
   特点：小尺寸、颜色变化、状态指示
   ======================================== */

/* 闰月切换按钮 - 用于切换闰月状态的特殊按钮 */
.leap-month-toggle {
  width: 20px;                   /* 固定宽度，小尺寸 */
  height: 20px;                  /* 固定高度，小尺寸 */
  border: 1px solid #D0D0D0;     /* 特殊边框颜色 */
  border-radius: 5px;            /* 小圆角 */
  background-color: var(--bg-gray-dark);    /* 深灰背景 */
  color: var(--text-primary);     /* 主要文本颜色 */
  font-size: var(--font-size-xs);         /* 极小字体 */
  font-weight: 500;              /* 中等字重 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: all var(--transition-normal); /* 正常过渡效果 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  justify-content: center;       /* 水平居中对齐 */
  padding: 0;                    /* 无内边距 */
  margin-top: 11px;              /* 顶部外边距，与其他元素对齐 */
}

/* 闰月切换按钮悬停状态 */
.leap-month-toggle:hover {
  background-color: #E0E0E0;     /* 更亮的背景，增强悬停反馈 */
  border-color: #B0B0B0;         /* 更深的边框颜色 */
}

/* 闰月切换按钮焦点状态 */
.leap-month-toggle:focus {
  outline: none;                 /* 移除默认轮廓 */
  border-color: var(--primary-color);      /* 主色边框，突出焦点 */
  box-shadow: 0 0 0 2px var(--primary-focus);  /* 外发光效果，增强焦点提示 */
}

/* 闰月切换按钮激活状态 - 表示闰月已开启 */
.leap-month-toggle.active {
  background-color: #D4EBD9;     /* 浅绿色背景，表示激活状态 */
  border-color: #289846;         /* 深绿色边框，强调激活状态 */
  color: var(--text-primary);     /* 保持主要文本颜色 */
}

/* 闰月切换按钮激活状态的悬停效果 */
.leap-month-toggle.active:hover {
  background-color: #C9E6D0;     /* 更亮的浅绿色背景 */
  border-color: #A5D9B0;         /* 更亮的绿色边框 */
}

/* 闰月切换按钮禁用状态 */
.leap-month-toggle:disabled {
  background-color: var(--border-disabled);  /* 禁用边框颜色作为背景 */
  border-color: var(--border-disabled);     /* 禁用边框颜色 */
  color: var(--text-disabled);     /* 禁用文本颜色 */
  cursor: not-allowed;           /* 禁用鼠标指针 */
  opacity: 0.5;                  /* 半透明，进一步表示禁用 */
}

/* ========================================
   警告弹窗组件 - 用于显示错误和警告信息
   设计思路：使用固定定位覆盖全屏，居中显示警告内容
   特点：高层级、简洁布局、单按钮操作
   ======================================== */

/* 警告弹窗遮罩层 - 覆盖全屏的半透明背景 */
.alert-overlay {
  position: fixed;               /* 固定定位，相对于视口 */
  top: 0;                        /* 顶部对齐 */
  left: 0;                       /* 左侧对齐 */
  right: 0;                      /* 右侧对齐 */
  bottom: 0;                     /* 底部对齐 */
  background-color: rgba(0, 0, 0, 0.5);  /* 半透明黑色背景，淡化背景内容 */
  display: flex;                 /* 使用 Flexbox 布局 */
  justify-content: center;       /* 水平居中 */
  align-items: center;           /* 垂直居中 */
  z-index: var(--z-alert);        /* 警告弹窗层级，确保在最上层 */
}

/* 警告弹窗内容区 - 实际的警告内容 */
.alert-content {
  background-color: var(--bg-white);       /* 白色背景 */
  border-radius: var(--radius-lg);         /* 大圆角 */
  box-shadow: var(--shadow-md);            /* 中等阴影，营造层次感 */
  padding: var(--spacing-3xl);            /* 较大的内边距，提供舒适的阅读体验 */
  max-width: 400px;              /* 最大宽度限制 */
  width: 90%;                    /* 宽度占视口的 90% */
  text-align: center;            /* 文本居中对齐 */
}

/* 警告消息文本 - 显示警告或错误信息 */
.alert-message {
  font-size: var(--font-size-lg);         /* 大字体，突出重要信息 */
  color: var(--text-primary);             /* 主要文本颜色 */
  margin-bottom: var(--spacing-2xl);      /* 底部间距，与按钮分开 */
  line-height: 1.5;             /* 行高，提高可读性 */
}

/* 警告关闭按钮 - 用于关闭警告弹窗 */
.alert-close {
  background-color: var(--primary-color);  /* 主色背景 */
  color: var(--bg-white);                  /* 白色文本 */
  border: none;                            /* 无边框 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  padding: var(--spacing-sm) var(--spacing-3xl);  /* 内边距，较大的左右内边距 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
}

/* 警告关闭按钮悬停状态 */
.alert-close:hover {
  background-color: var(--primary-hover);   /* 主色悬停态，增强交互反馈 */
}

/* ========================================
   时间戳显示区 - 显示阳历和阴历时间信息
   设计思路：使用卡片式布局，清晰展示不同历法的时间信息
   特点：浅色背景、居中对齐、标签与值分离
   ======================================== */

/* 时间戳显示容器 - 包含所有时间信息的区域 */
.timestamp-display {
  background-color: var(--bg-gray-light);  /* 浅灰背景，区别于主要内容区 */
  padding: 15px;               /* 内边距 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  display: flex;                 /* 使用 Flexbox 布局 */
  flex-direction: column;        /* 垂直排列 */
  align-items: center;           /* 水平居中对齐 */
  text-align: center;            /* 文本居中对齐 */
}

/* 阳历信息 - 显示阳历日期和时间 */
.solar-info {
  margin-bottom: var(--spacing-md);        /* 底部间距，与阴历信息分开 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 阴历信息 - 显示阴历日期和时间 */
.lunar-info {
  margin-bottom: var(--spacing-md);        /* 底部间距 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 阳历和阴历信息的最后一个元素 - 移除底部间距 */
.solar-info:last-child,
.lunar-info:last-child {
  margin-bottom: 0;             /* 移除底部间距 */
}

/* 阳历标签 - 阳历信息的标签文本 */
.solar-label {
  font-weight: 600;              /* 加粗字体，突出标签 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 日期标签 - 通用日期标签 */
.date-label {
  font-weight: 600;              /* 加粗字体，突出标签 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 时间标签 - 通用时间标签 */
.time-label {
  font-weight: 600;              /* 加粗字体，突出标签 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 日期值 - 显示具体的日期 */
.date-value {
  color: var(--text-primary);    /* 主要文本颜色 */
  display: inline-block;        /* 内联块级元素 */
  width: 120px;                 /* 固定宽度，确保对齐 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* 时间值 - 显示具体的时间 */
.time-value {
  color: var(--text-primary);    /* 主要文本颜色 */
  display: inline-block;        /* 内联块级元素 */
  width: 60px;                  /* 固定宽度，确保对齐 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
}

/* ========================================
   模态框底部按钮区 - 包含操作按钮
   设计思路：使用浅色背景区分底部，提供清晰的视觉层次
   特点：多种按钮类型、禁用状态、特殊布局
   ======================================== */

/* 时间戳模态框底部 - 特殊的时间选择模态框底部 */
.timestamp-modal-footer {
  justify-content: flex-start;   /* 左对齐 */
  gap: var(--spacing-2xl);       /* 较大的按钮间距 */
}

/* 时间戳模态框底部按钮 - 统一的按钮样式 */
.timestamp-modal-footer .modal-button {
  width: 72px;                   /* 固定宽度 */
  height: 32px;                  /* 固定高度，与输入框一致 */
  padding: var(--spacing-xs) var(--spacing-lg);  /* 内边距 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  border-radius: var(--radius-md);         /* 中等圆角 */
}

/* 初始化按钮 - 特殊的初始化按钮，位于左侧 */
.timestamp-modal-footer .modal-button.initialize {
  margin-right: auto;            /* 自动右边距，推到最左侧 */
}

/* 初始化按钮非禁用状态 - 警告色，表示重要操作 */
.timestamp-modal-footer .modal-button.initialize:not(:disabled) {
  background-color: var(--warning-color);   /* 警告色背景 */
  color: var(--bg-white);                  /* 白色文本 */
  border-color: var(--warning-color);     /* 警告色边框 */
}

/* 初始化按钮非禁用状态的悬停效果 */
.timestamp-modal-footer .modal-button.initialize:not(:disabled):hover {
  background-color: var(--warning-hover);   /* 警告色悬停态 */
  border-color: var(--warning-hover);      /* 警告色边框悬停态 */
}

/* ========================================
   模态框通用组件 - 标题、关闭按钮、内容区、底部按钮
   设计思路：提供通用的模态框组件样式，确保一致性
   特点：清晰的视觉层次、标准化的交互反馈
   ======================================== */

/* 模态框标题 - 模态框的主标题 */
.modal-header h3 {
  margin: 0;                     /* 移除默认外边距 */
  font-size: var(--font-size-lg);         /* 大字体，突出标题 */
  font-weight: 600;              /* 加粗字体 */
  color: var(--text-primary);    /* 主要文本颜色 */
}

/* 模态框关闭按钮 - 右上角的关闭按钮 */
.modal-close {
  background: none;               /* 无背景 */
  border: none;                  /* 无边框 */
  font-size: var(--font-size-xl);         /* 超大字体，使用 × 符号 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  color: var(--text-secondary);   /* 次要文本颜色 */
  padding: 0;                     /* 无内边距 */
  width: 24px;                   /* 固定宽度 */
  height: 24px;                  /* 固定高度 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  justify-content: center;       /* 水平居中对齐 */
  border-radius: var(--radius-sm);         /* 小圆角 */
}

/* 模态框关闭按钮悬停状态 */
.modal-close:hover {
  background-color: var(--bg-gray-medium);  /* 中灰背景，突出悬停 */
  color: var(--text-primary);     /* 主要文本颜色 */
}

/* 模态框内容区 - 模态框的主要内容区域 */
.modal-body {
  padding: var(--spacing-2xl);  /* 内边距 */
}

/* 模态框底部 - 包含操作按钮的区域 */
.modal-footer {
  display: flex;                 /* 使用 Flexbox 布局 */
  justify-content: flex-end;     /* 右对齐 */
  gap: var(--spacing-lg);        /* 按钮间距 */
  padding: var(--spacing-xl) var(--spacing-2xl);  /* 内边距 */
  border-top: 1px solid var(--border-color);   /* 顶部边框，区分底部和内容 */
  background-color: var(--bg-gray-light);  /* 浅灰背景，突出底部区域 */
}

/* ========================================
   模态框按钮 - 通用按钮样式
   设计思路：提供多种按钮类型，适应不同的操作场景
   特点：语义化颜色、禁用状态、悬停效果
   ======================================== */

/* 模态框按钮 - 通用按钮样式 */
.modal-button {
  padding: var(--spacing-md) var(--spacing-xl);  /* 内边距 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
}

/* 取消按钮 - 用于取消操作 */
.modal-button.cancel {
  background-color: var(--bg-white);       /* 白色背景 */
  color: var(--text-secondary);  /* 次要文本颜色 */
}

/* 取消按钮悬停状态 */
.modal-button.cancel:hover {
  background-color: var(--bg-gray-medium);  /* 中灰背景，增强悬停反馈 */
  border-color: var(--border-disabled);     /* 禁用边框颜色 */
}

/* 确认按钮 - 用于确认操作 */
.modal-button.confirm {
  background-color: var(--primary-color);   /* 主色背景 */
  color: var(--bg-white);                  /* 白色文本 */
  border-color: var(--primary-color);      /* 主色边框 */
}

/* 确认按钮悬停状态 */
.modal-button.confirm:hover {
  background-color: var(--primary-hover);   /* 主色悬停态 */
  border-color: var(--primary-hover);      /* 主色边框悬停态 */
}

/* 提交按钮 - 用于提交表单 */
.modal-button.submit {
  background-color: var(--success-color);   /* 成功色背景 */
  color: var(--bg-white);                   /* 白色文本 */
  border-color: var(--success-color);      /* 成功色边框 */
}

/* 提交按钮悬停状态 */
.modal-button.submit:hover {
  background-color: var(--success-hover);   /* 成功色悬停态 */
  border-color: var(--success-hover);      /* 成功色边框悬停态 */
}

/* 模态框按钮禁用状态 - 所有按钮的禁用状态 */
.modal-button:disabled {
  opacity: 0.5;                  /* 半透明，表示禁用 */
  cursor: not-allowed;           /* 禁用鼠标指针 */
  background-color: var(--border-disabled);  /* 禁用边框颜色作为背景 */
  border-color: var(--border-disabled);     /* 禁用边框颜色 */
  color: var(--text-disabled);     /* 禁用文本颜色 */
}

/* ========================================
   结果列表组件 - 显示占卜结果列表
   设计思路：使用卡片式布局，支持滚动和选中状态
   特点：自定义滚动条、悬停效果、选中高亮、错误提示
   ======================================== */

/* 阳历结果列表容器 - 包含结果列表的区域 */
.solar-list-result {
  margin-top: 10px;              /* 顶部外边距 */
  padding: 10px;                 /* 内边距 */
  background-color: var(--bg-gray-light);  /* 浅灰背景，区别于主要内容区 */
  border-radius: var(--radius-md);         /* 中等圆角 */
  border: 1px solid var(--border-color);   /* 边框颜色 */
}

/* 结果列表 - 可滚动的结果项列表 */
.result-list {
  display: flex;                 /* 使用 Flexbox 布局 */
  flex-direction: column;        /* 垂直排列 */
  gap: var(--spacing-md);        /* 结果项间距 */
  max-height: 200px;             /* 最大高度，超出后滚动 */
  overflow-y: auto;              /* 垂直滚动 */
  padding-right: 4px;            /* 右侧内边距，为滚动条留出空间 */
  will-change: scroll-position;  /* 性能优化，提示浏览器滚动位置会变化 */
}

/* 自定义滚动条 - Webkit 浏览器（Chrome、Safari、Edge） */
.result-list::-webkit-scrollbar {
  width: 6px;                   /* 滚动条宽度 */
}

/* 滚动条轨道 */
.result-list::-webkit-scrollbar-track {
  background: var(--bg-gray-medium);  /* 中灰背景 */
  border-radius: 3px;          /* 小圆角 */
}

/* 滚动条滑块 */
.result-list::-webkit-scrollbar-thumb {
  background: #C1C1C1;          /* 灰色滑块 */
  border-radius: 3px;          /* 小圆角 */
}

/* 滚动条滑块悬停状态 */
.result-list::-webkit-scrollbar-thumb:hover {
  background: #A8A8A8;          /* 更深的灰色，增强交互反馈 */
}

/* 结果项 - 单个结果项 */
.result-item {
  height: 40px;                  /* 固定高度 */
  display: flex;                 /* 使用 Flexbox 布局 */
  align-items: center;           /* 垂直居中对齐 */
  justify-content: flex-start;   /* 左对齐 */
  padding: 10px;                 /* 内边距 */
  background-color: var(--bg-white);       /* 白色背景 */
  border-radius: var(--radius-sm);         /* 小圆角 */
  border: 1px solid var(--border-color);   /* 默认边框颜色 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  color: var(--text-primary);    /* 主要文本颜色 */
  gap: var(--spacing-lg);        /* 元素间距 */
  cursor: pointer;               /* 鼠标指针，提示可点击 */
  transition: all var(--transition-fast);   /* 快速过渡效果 */
}

/* 结果项悬停状态 */
.result-item:hover {
  background-color: var(--bg-gray-light);  /* 浅灰背景，突出悬停项 */
  border-color: var(--primary-color);      /* 主色边框，增强交互反馈 */
}

/* 结果项选中状态 - 当前选中的结果 */
.result-item.selected {
  background-color: var(--primary-light);  /* 主色浅色背景，突出选中 */
  border-color: var(--primary-color);      /* 主色边框，强调选中状态 */
}

/* 结果项选中状态的悬停效果 */
.result-item.selected:hover {
  background-color: #BAE7FF;     /* 更亮的主色浅色背景 */
}

/* 结果索引 - 结果项的序号 */
.result-index {
  font-size: var(--font-size-base);        /* 基础字体大小 */
  color: var(--text-secondary);  /* 次要文本颜色 */
  font-weight: 500;              /* 中等字重 */
  min-width: 50px;               /* 最小宽度，确保对齐 */
}

/* 结果内容 - 结果项的主要内容 */
.result-content {
  font-size: var(--font-size-base);        /* 基础字体大小 */
  color: var(--text-primary);    /* 主要文本颜色 */
  flex: 1;                       /* 弹性布局，占据剩余空间 */
}

/* 结果错误提示 - 显示错误信息 */
.result-error {
  padding: 10px;                 /* 内边距 */
  background-color: var(--warning-bg);     /* 警告背景色 */
  border: 1px solid var(--warning-border); /* 警告边框色 */
  border-radius: var(--radius-sm);         /* 小圆角 */
  color: var(--warning-color);    /* 警告文本颜色 */
  font-size: var(--font-size-base);        /* 基础字体大小 */
  text-align: center;            /* 文本居中对齐 */
}
